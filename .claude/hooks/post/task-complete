#!/bin/bash
# Post-Task Verification Hook
# Task 완료 시 자동 검증 (병렬 실행 타이밍 이슈 방지)

set -euo pipefail

# 입력 파라미터
TASK_ID="${1:-}"
AGENT_TYPE="${2:-}"
EXIT_CODE="${3:-0}"

# 로깅 함수
log() {
  echo "[task-complete] $1" >&2
}

# 빈 입력 처리 (Graceful Degradation)
if [[ -z "$TASK_ID" ]]; then
  log "Skipped: empty TASK_ID"
  exit 0
fi

# 경고 파일 경로
WARNING_FILE="/tmp/claude-task-warnings.log"

# 1. Task 파일 확인
TASK_FILE=$(find docs/epics -name "${TASK_ID}*.md" 2>/dev/null | head -1)
if [[ -z "$TASK_FILE" ]]; then
  log "⚠️ Task 파일 없음: $TASK_ID (조기 종료 의심)"
  echo "⚠️ Task $TASK_ID: 파일 없음 (조기 종료 의심)" >> "$WARNING_FILE"
  exit 0
fi

log "✓ Task 파일 확인: $TASK_FILE"

# 2. 체크박스 상태 확인
UNCHECKED=$(grep -c "^- \[ \]" "$TASK_FILE" 2>/dev/null || echo "0")
CHECKED=$(grep -c "^- \[x\]" "$TASK_FILE" 2>/dev/null || echo "0")

if [[ $UNCHECKED -gt 0 ]]; then
  log "⚠️ 미완료 체크박스 ${UNCHECKED}개 / 완료 ${CHECKED}개"
  echo "⚠️ Task $TASK_ID: 불완전 (미완료 ${UNCHECKED}개, 완료 ${CHECKED}개)" >> "$WARNING_FILE"
else
  log "✓ 체크박스 검증 통과 (완료 ${CHECKED}개)"
fi

# 3. code-writer 특별 검증
if [[ "$AGENT_TYPE" == *"code-writer"* ]]; then
  # 변경된 파일 섹션 확인
  if grep -q "## 변경된 파일" "$TASK_FILE" 2>/dev/null; then
    CHANGED_COUNT=$(grep -A 20 "## 변경된 파일" "$TASK_FILE" | grep -c "^- " || echo "0")
    if [[ $CHANGED_COUNT -eq 0 ]]; then
      log "❌ code-writer 완료했으나 변경 파일 없음"
      echo "❌ Task $TASK_ID: 구현 실패 (파일 변경 없음)" >> "$WARNING_FILE"
    else
      log "✓ 변경 파일 확인: ${CHANGED_COUNT}개"
    fi
  fi
fi

# 4. Exit code 확인
if [[ $EXIT_CODE -ne 0 ]]; then
  log "❌ Task 실패: Exit code $EXIT_CODE"
  echo "❌ Task $TASK_ID: 실패 (Exit code $EXIT_CODE)" >> "$WARNING_FILE"
fi

# 5. 검증 요약
if [[ -f "$WARNING_FILE" ]]; then
  WARNINGS=$(grep -c "$TASK_ID" "$WARNING_FILE" 2>/dev/null || echo "0")
  if [[ $WARNINGS -gt 0 ]]; then
    log "⚠️ 총 ${WARNINGS}개 경고 발생 (확인 필요)"
  fi
else
  log "✅ 검증 통과 (경고 없음)"
fi

exit 0
