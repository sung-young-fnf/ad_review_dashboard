{
  "includeGitInstructions": false,
  "worktree": {
    "symlinkDirectories": [
      "node_modules",
      ".next",
      ".cache"
    ]
  },
  "env": {
    "CLAUDE_CODE_SESSIONEND_HOOKS_TIMEOUT_MS": "15000",
    "CLAUDE_CODE_SUBPROCESS_ENV_SCRUB": "1",
    "CLAUDE_CODE_SCRIPT_CAPS": "5000"
  },
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git fetch*)",
      "Bash(git rev-parse*)",
      "Bash(git remote*)",
      "Bash(pnpm build*)",
      "Bash(pnpm lint*)",
      "Bash(pnpm test*)",
      "Bash(pnpm tsc*)",
      "Bash(pnpm typecheck*)",
      "Bash(pnpm list*)",
      "Bash(pnpm why*)",
      "Bash(uv run python *)",
      "Bash(uv pip list*)",
      "Bash(kubectl get *)",
      "Bash(kubectl describe *)",
      "Bash(kubectl logs *)",
      "Bash(kubectl config view*)",
      "Bash(docker ps*)",
      "Bash(docker images*)",
      "Bash(docker logs *)",
      "Bash(docker inspect *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(* DROP TABLE*)",
      "Bash(* DROP DATABASE*)",
      "Bash(* TRUNCATE *)",
      "Bash(prisma migrate reset*)",
      "Bash(prisma db push --force-reset*)"
    ]
  },
  "hooks": {
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre/subagent-start.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post/squad-event-logger.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre/auto-approve-safe-commands.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre/db-destructive-guard.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post/session-start-loader.sh",
            "timeout": 10,
            "once": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre/user-prompt-submit-unified.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre/user-correction-detector.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre/session-title-setter.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post/trajectory-warning.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post/intent-disambiguator.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre/commit-quality-gate.sh",
            "timeout": 30,
            "if": "Bash(git commit*)"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre/affected-app-detector.sh",
            "timeout": 5,
            "if": "Bash(git commit*)"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre/approach-checkpoint.sh",
            "timeout": 3,
            "if": "Edit(*.tsx)|Write(*.tsx)"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|Task",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre/service-detection-context-injector.sh",
            "timeout": 3,
            "if": "Edit(apps/*)|Write(apps/*)|MultiEdit(apps/*)|Task"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre/test-file-write-guard.sh",
            "timeout": 3,
            "if": "Edit(*.test.*)|Edit(*.spec.*)|Write(*.test.*)|Write(*.spec.*)"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre/sensitive-file-guard.sh",
            "timeout": 3,
            "if": "Edit(*/alembic/*)|Write(*/alembic/*)|Edit(*/prisma/*)|Write(*/prisma/*)|Edit(*/auth/*)|Write(*/auth/*)|Edit(*/guards/*)|Write(*/guards/*)|Edit(*guard*)|Write(*guard*)|Edit(*encrypt*)|Write(*encrypt*)|Edit(*crypto*)|Write(*crypto*)|Edit(*settings*)|Write(*settings*)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post/read-tracker.sh",
            "timeout": 2
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post/commit-changelog-recorder.sh",
            "timeout": 5,
            "if": "Bash(git commit*)|Bash(git merge*)|Bash(git revert*)"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post/repeated-file-ref-reminder.sh",
            "timeout": 5,
            "if": "Bash(git commit*)"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post/test-quality-checker.sh",
            "timeout": 3,
            "if": "Write(*.test.*)|Write(*.spec.*)"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post/dependency-sync-checker.sh",
            "timeout": 3,
            "if": "Write(package.json)|Write(*/package.json)"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post/dependency-sync-checker.sh",
            "timeout": 3,
            "if": "Edit(package.json)|Edit(*/package.json)"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post/code-writer-retry-handler.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post/agent-complete.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post/self-improve-recorder.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post/squad-event-logger.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post/trajectory-logger.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post/stream-timeout-guard.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop/ralph-loop-enforcer.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post/session-end-summary.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post/teammate-idle-handler.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post/task-created-validator.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post/squad-event-logger.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post/task-completed-handler.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post/squad-event-logger.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post/config-change-auditor.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post/worktree-init.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post/worktree-cleanup.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre/cwd-service-detector.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": "CLAUDE.md|settings.json|.claude/rules/*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post/config-change-auditor.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop/stop-failure-handler.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
