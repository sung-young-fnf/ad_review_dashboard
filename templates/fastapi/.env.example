# Database (DBUSER 정책: _svc 계정으로 접속, 전용 스키마)
{{APP_NAME_SNAKE}}_DATABASE_URL=postgresql+asyncpg://{{APP_NAME_SNAKE}}_svc:changeme@localhost:5432/{{APP_NAME_SNAKE}}_db
{{APP_NAME_SNAKE}}_DATABASE_URL_SYNC=postgresql://{{APP_NAME_SNAKE}}_svc:changeme@localhost:5432/{{APP_NAME_SNAKE}}_db
{{APP_NAME_SNAKE}}_DB_SCHEMA={{APP_NAME_SNAKE}}

# JWT
{{APP_NAME_SNAKE}}_JWT_SECRET_KEY=change-me-in-production

# CORS
{{APP_NAME_SNAKE}}_CORS_ORIGINS=["http://localhost:{{FRONTEND_PORT}}"]
