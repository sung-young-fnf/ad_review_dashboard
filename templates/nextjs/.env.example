# Backend API (서버사이드 전용 — NEXT_PUBLIC_ 아님)
BACKEND_URL=http://localhost:8000

# NextAuth.js v5
AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:{{FRONTEND_PORT}}

# Microsoft Entra ID SSO (--sso 선택 시)
# AZURE_AD_CLIENT_ID=your-client-id
# AZURE_AD_CLIENT_SECRET=your-client-secret
# AZURE_AD_TENANT_ID=your-tenant-id
#
# Federated logout(/api/auth/federated-logout): 로그아웃 시 Entra SSO 세션까지 종료.
# AZURE_AD_TENANT_ID 를 재사용하며, NEXTAUTH_URL + "/login" 을 post_logout_redirect_uri 로 보낸다.
# 이 주소를 Entra App Registration 의 허용 redirect(또는 front-channel logout URL) 에 등록해야 한다.

# Public env (빌드 시 인라인 — 런타임 변경 불가)
# NEXT_PUBLIC_APP_NAME={{APP_NAME}}
