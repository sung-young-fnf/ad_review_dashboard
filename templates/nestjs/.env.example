# Database (DBUSER 정책: _svc 계정, 전용 스키마)
# 앱 런타임 (DML 전용)
DATABASE_URL=postgresql://{{APP_NAME_SNAKE}}_svc:changeme@localhost:5432/{{APP_NAME_SNAKE}}_db?schema={{APP_NAME_SNAKE}}
# Read Replica (프로덕션에서만 분리, 로컬은 동일 URL)
DATABASE_READER_URL=postgresql://{{APP_NAME_SNAKE}}_svc:changeme@localhost:5432/{{APP_NAME_SNAKE}}_db?schema={{APP_NAME_SNAKE}}&connection_limit=15&pool_timeout=30
# Prisma Migrate (DDL, _ops 계정)
MIGRATE_DATABASE_URL=postgresql://{{APP_NAME_SNAKE}}_prisma_ops:changeme@localhost:5432/{{APP_NAME_SNAKE}}_db?schema={{APP_NAME_SNAKE}}

# JWT
JWT_SECRET=change-me-in-production

# CORS
CORS_ORIGINS=http://localhost:{{FRONTEND_PORT}}
