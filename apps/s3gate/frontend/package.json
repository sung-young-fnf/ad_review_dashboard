{
  "name": "@ad_review_dashboard/s3gate-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3100",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "fetch:openapi": "cp ../backend/openapi.json ./openapi.json",
    "generate:types": "openapi-typescript ./openapi.json -o ./src/types/generated/api.ts",
    "generate:api": "pnpm fetch:openapi && pnpm generate:types"
  },
  "dependencies": {
    "next": "^16.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "lucide-react": "^0.468.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0",
    "class-variance-authority": "^0.7.1",
    "tailwindcss-animate": "^1.0.7",
    "next-auth": "^5.0.0-beta.25"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "^16.0.0",
    "postcss": "^8.5.0",
    "openapi-typescript": "^7.6.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.0"
  }
}
